<?xml version="1.0"?>
<!--
/**
 * Robots Policies admin grid layout. Renders the
 * `panth_robots_seo_policy_listing` UI component on the
 * `panth_robots_seo/policy/index` page.
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="admin-1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="styles"/>
    <body>
        <referenceContainer name="content">
            <uiComponent name="panth_robots_seo_policy_listing"/>
        </referenceContainer>
    </body>
</page>
