<?xml version="1.0"?>
<!--
/**
 * Panth Robots SEO — Adminhtml layout for the robots.txt preview page.
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="styles"/>
    <body>
        <referenceContainer name="content">
            <block class="Panth\RobotsSeo\Block\Adminhtml\Robots"
                   name="panth_robots_seo.robots"
                   template="Panth_RobotsSeo::robots.phtml"/>
        </referenceContainer>
    </body>
</page>
