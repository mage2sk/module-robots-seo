<?xml version="1.0"?>
<!--
/**
 * Edit existing robots-policy row. Renders the `panth_robots_seo_policy_form`
 * UI component on `panth_robots_seo/policy/edit/policy_id/<ID>`.
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="admin-1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="styles"/>
    <body>
        <referenceContainer name="content">
            <uiComponent name="panth_robots_seo_policy_form"/>
        </referenceContainer>
    </body>
</page>
