{
    "name": "mage2kishan/module-robots-seo",
    "description": "Panth Robots SEO — dedicated robots.txt, X-Robots-Tag, and LLM-bot (GPTBot, ClaudeBot, PerplexityBot, Google-Extended, etc.) policy control for Magento 2. Extracted from Panth_AdvancedSEO. Self-contained: emits a per-store robots.txt, adds X-Robots-Tag response headers, validates robots meta directives, and exposes admin CRUD for user-agent / path policies. Hyva and Luma compatible.",
    "type": "magento2-module",
    "version": "1.0.4",
    "license": "proprietary",
    "keywords": [
        "magento2",
        "magento2-module",
        "panth",
        "robots",
        "robots-txt",
        "x-robots-tag",
        "llm-bots",
        "gptbot",
        "claudebot",
        "perplexitybot",
        "seo",
        "hyva",
        "luma"
    ],
    "homepage": "https://kishansavaliya.com",
    "support": {
        "email": "kishansavaliyakb@gmail.com",
        "source": "https://kishansavaliya.com"
    },
    "authors": [
        {
            "name": "Kishan Savaliya",
            "email": "kishansavaliyakb@gmail.com",
            "homepage": "https://kishansavaliya.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "~8.1.0||~8.2.0||~8.3.0||~8.4.0",
        "mage2kishan/module-core": "^1.0",
        "magento/framework": "^103.0",
        "magento/module-store": "^101.1",
        "magento/module-backend": "^102.0",
        "magento/module-config": "^101.2",
        "magento/module-catalog": "^104.0",
        "magento/module-cms": "^104.0",
        "magento/module-ui": "^101.2"
    },
    "suggest": {
        "hyva-themes/magento2-default-theme": "For Hyva frontend compatibility (no jQuery, TailwindCSS, AlpineJS)."
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Panth\\RobotsSeo\\": ""
        }
    }
}
