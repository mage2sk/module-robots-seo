<?xml version="1.0"?>
<!--
/**
 * Panth Robots SEO — Frontend-only DI.
 *
 * Replaces Magento\Robots\Controller\Router with Panth's so /robots.txt
 * dispatches directly to Panth_RobotsSeo's Robots/Index controller. The
 * previous "disable Magento_Robots router + rely on url_rewrite" approach
 * was unreliable: the disable override didn't always merge, and the Base
 * router could short-circuit .txt paths to 404 before url_rewrite ran.
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <preference for="Magento\Robots\Controller\Router"
                type="Panth\RobotsSeo\Controller\Router\RobotsRouter"/>

    <!-- X-Robots-Tag plugin: frontend-only. -->
    <type name="Magento\Framework\App\Response\Http">
        <plugin name="panth_robots_seo_x_robots_tag"
                type="Panth\RobotsSeo\Plugin\Response\XRobotsTagPlugin"
                sortOrder="10"/>
    </type>

    <!-- HTML <meta name="robots"> plugin: rewrites the tag so it matches
         the X-Robots-Tag header and reflects per-path noindex rules. -->
    <type name="Magento\Framework\View\Page\Config">
        <plugin name="panth_robots_seo_meta_robots"
                type="Panth\RobotsSeo\Plugin\Page\RobotsMetaPlugin"
                sortOrder="20"/>
    </type>
</config>
