<?xml version="1.0"?>
<!--
/**
 * Panth Robots SEO — ACL
 *
 * Two-branch ACL: the Panth_Core::panth_extensions branch gates the direct
 * menu links, and the Magento_Config::config branch gates the system.xml
 * section.
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Panth_Core::panth_extensions">
                    <resource id="Panth_RobotsSeo::manage"
                              title="Panth Robots &amp; LLM Bots"
                              sortOrder="40">
                        <resource id="Panth_RobotsSeo::robots"
                                  title="robots.txt Preview"
                                  sortOrder="10"/>
                        <resource id="Panth_RobotsSeo::policies"
                                  title="Robots Policies"
                                  sortOrder="20">
                            <resource id="Panth_RobotsSeo::policies_save"
                                      title="Save / Delete Robots Policies"
                                      sortOrder="10"/>
                        </resource>
                        <resource id="Panth_RobotsSeo::config"
                                  title="Panth Robots SEO Configuration"
                                  sortOrder="30"/>
                    </resource>
                </resource>

                <resource id="Magento_Backend::stores">
                    <resource id="Magento_Backend::stores_settings">
                        <resource id="Magento_Config::config">
                            <resource id="Panth_RobotsSeo::config"
                                      title="Panth Robots SEO Configuration"
                                      sortOrder="400"/>
                        </resource>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
